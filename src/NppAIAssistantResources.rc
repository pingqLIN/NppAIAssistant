#include <windows.h>
#include "NppAIAssistantResources.h"
#include "NppAIAssistantVersion.h"

IDD_AIASSISTANT_PANEL DIALOGEX 0, 0, 280, 300
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_TOOLWINDOW | WS_EX_WINDOWEDGE
CAPTION "AI Assistant"
FONT 9, "Segoe UI", 400, 0, 0x0
BEGIN
    COMBOBOX        IDC_AI_PROVIDER_COMBO, 5, 7, 50, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    COMBOBOX        IDC_AI_MODEL_COMBO, 58, 7, 100, 200, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Sign in", IDC_AI_COPILOT_SIGNIN_BUTTON, 132, 6, 30, 14
    PUSHBUTTON      "A+", IDC_AI_FONT_INCREASE_BUTTON, 166, 6, 18, 14
    PUSHBUTTON      "A-", IDC_AI_FONT_DECREASE_BUTTON, 186, 6, 18, 14
    PUSHBUTTON      "Settings", IDC_AI_SETTINGS_BUTTON, 208, 6, 35, 14
    PUSHBUTTON      "Clear", IDC_AI_CLEAR_BUTTON, 246, 6, 28, 14

    EDITTEXT        IDC_AI_CHAT_HISTORY, 5, 26, 270, 230, ES_MULTILINE | ES_READONLY | ES_AUTOVSCROLL | WS_VSCROLL | WS_BORDER

    EDITTEXT        IDC_AI_INPUT_EDIT, 5, 260, 220, 35, ES_MULTILINE | ES_AUTOVSCROLL | WS_VSCROLL | WS_BORDER
    PUSHBUTTON      "Send", IDC_AI_SEND_BUTTON, 230, 260, 45, 35
END

IDD_AIASSISTANT_SETTINGS DIALOGEX 0, 0, 380, 590
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "AI Assistant Settings"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "OpenAI API Key:", IDC_OPENAI_KEY_LABEL, 10, 15, 72, 10
    EDITTEXT        IDC_OPENAI_KEY_EDIT, 88, 12, 280, 14, ES_AUTOHSCROLL | ES_PASSWORD

    LTEXT           "Gemini API Key:", IDC_GEMINI_KEY_LABEL, 10, 35, 72, 10
    EDITTEXT        IDC_GEMINI_KEY_EDIT, 88, 32, 280, 14, ES_AUTOHSCROLL | ES_PASSWORD

    LTEXT           "Claude API Key:", IDC_CLAUDE_KEY_LABEL, 10, 55, 72, 10
    EDITTEXT        IDC_CLAUDE_KEY_EDIT, 88, 52, 280, 14, ES_AUTOHSCROLL | ES_PASSWORD

    GROUPBOX        "Default Provider", IDC_DEFAULT_PROVIDER_GROUP, 10, 82, 360, 78
    LTEXT           "Select default AI provider:", IDC_DEFAULT_PROVIDER_LABEL, 20, 98, 110, 10
    COMBOBOX        IDC_DEFAULT_PROVIDER_COMBO, 140, 96, 120, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Language:", IDC_UI_LANGUAGE_LABEL, 20, 118, 90, 10
    COMBOBOX        IDC_UI_LANGUAGE_COMBO, 140, 116, 120, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX    "Require Ctrl+Enter to send from AI panel", IDC_SEND_SHORTCUT_CHECK, 20, 138, 250, 12, WS_TABSTOP

    GROUPBOX        "Single-turn Prompt Profile", IDC_PROMPT_PROFILE_GROUP, 10, 168, 360, 90
    LTEXT           "Preset:", IDC_PROMPT_PRESET_LABEL, 20, 184, 100, 10
    COMBOBOX        IDC_PROMPT_PRESET_COMBO, 140, 182, 160, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Response language:", IDC_RESPONSE_LANGUAGE_LABEL, 20, 202, 100, 10
    COMBOBOX        IDC_RESPONSE_LANGUAGE_COMBO, 140, 200, 130, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Encoding suggestion:", IDC_ENCODING_LABEL, 20, 220, 100, 10
    COMBOBOX        IDC_ENCODING_COMBO, 140, 218, 130, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Response detail:", IDC_DETAIL_LEVEL_LABEL, 20, 238, 100, 10
    COMBOBOX        IDC_DETAIL_LEVEL_COMBO, 140, 236, 130, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    GROUPBOX        "Scenario Modules", IDC_SCENARIO_GROUP, 10, 266, 360, 58
    AUTOCHECKBOX    "Explain code", IDC_SCENARIO_EXPLAIN_CHECK, 20, 282, 80, 12, WS_TABSTOP
    AUTOCHECKBOX    "Fix bugs", IDC_SCENARIO_FIX_CHECK, 110, 282, 70, 12, WS_TABSTOP
    AUTOCHECKBOX    "Refactor", IDC_SCENARIO_REFACTOR_CHECK, 200, 282, 70, 12, WS_TABSTOP
    AUTOCHECKBOX    "Generate tests", IDC_SCENARIO_TEST_CHECK, 20, 298, 90, 12, WS_TABSTOP
    AUTOCHECKBOX    "Write docs", IDC_SCENARIO_DOC_CHECK, 120, 298, 80, 12, WS_TABSTOP

    GROUPBOX        "Output Rules", IDC_OUTPUT_GROUP, 10, 332, 360, 44
    AUTOCHECKBOX    "Code only when suitable", IDC_OUTPUT_CODE_ONLY_CHECK, 20, 348, 100, 12, WS_TABSTOP
    AUTOCHECKBOX    "Preserve project style", IDC_OUTPUT_PRESERVE_STYLE_CHECK, 140, 348, 100, 12, WS_TABSTOP
    AUTOCHECKBOX    "Mention risks and assumptions", IDC_OUTPUT_RISKS_CHECK, 250, 348, 100, 12, WS_TABSTOP

    GROUPBOX        "Prompt Preview", IDC_CUSTOM_PROMPT_GROUP, 10, 384, 360, 110
    EDITTEXT        IDC_CUSTOM_PROMPT_EDIT, 20, 400, 340, 78, ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL | WS_BORDER

    GROUPBOX        "How to get API Keys", IDC_API_KEYS_GROUP, 10, 500, 360, 52
    LTEXT           "OpenAI: platform.openai.com - API Keys", IDC_API_KEYS_OPENAI_HINT, 20, 514, 330, 10
    LTEXT           "Gemini: ai.google.dev - Get API Key", IDC_API_KEYS_GEMINI_HINT, 20, 526, 330, 10
    LTEXT           "Claude: console.anthropic.com - API Keys", IDC_API_KEYS_CLAUDE_HINT, 20, 538, 330, 10

    PUSHBUTTON      "Test Default Connection", IDC_TEST_CONNECTION_BTN, 10, 558, 110, 20
    DEFPUSHBUTTON   "OK", IDOK, 270, 558, 45, 20
    PUSHBUTTON      "Cancel", IDCANCEL, 320, 558, 50, 20
END

VS_VERSION_INFO VERSIONINFO
 FILEVERSION NPPAI_VERSION_MAJOR, NPPAI_VERSION_MINOR, NPPAI_VERSION_PATCH, NPPAI_VERSION_BUILD
 PRODUCTVERSION NPPAI_VERSION_MAJOR, NPPAI_VERSION_MINOR, NPPAI_VERSION_PATCH, NPPAI_VERSION_BUILD
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x2L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", NPPAI_COMPANY_NAME
            VALUE "FileDescription", NPPAI_FILE_DESCRIPTION
            VALUE "FileVersion", NPPAI_VERSION_STRING_FULL
            VALUE "InternalName", NPPAI_PRODUCT_NAME
            VALUE "LegalCopyright", NPPAI_COPYRIGHT
            VALUE "OriginalFilename", "NppAIAssistant.dll"
            VALUE "ProductName", NPPAI_PRODUCT_NAME
            VALUE "ProductVersion", NPPAI_VERSION_STRING_FULL
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
